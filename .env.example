# Copy this file to .env and fill in your key:
#   copy .env.example .env
#
# Never commit .env — it is gitignored. Docker Compose reads this file via env_file.

# --- OpenAI (NL -> spec/motor, chat agent) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5.4-nano

# --- Postgres (E2 persistence) ---
POSTGRES_USER=copilot
POSTGRES_PASSWORD=copilot
POSTGRES_DB=copilot
# Inside Compose the host is the service name `db`. For host-run tools use localhost:
#   DATABASE_URL=postgresql+psycopg://copilot:copilot@localhost:5432/copilot
DATABASE_URL=postgresql+psycopg://copilot:copilot@db:5432/copilot

# --- Redis (queue + pub/sub + rate limits) ---
# Inside Compose the host is `redis`; for host-run tools use localhost.
REDIS_URL=redis://redis:6379/0
DESIGN_QUEUE=copilot

# --- Persistence (E2.2) ---
# When true, the job store is backed by Postgres (state survives restarts + reaches the
# worker). Docker Compose sets this for the api/worker; leave unset for host tools/tests.
# COPILOT_PERSIST=true
# COPILOT_DB_ECHO=false

# --- Async design runs (E2.3) ---
# When true, CPU-heavy design runs are enqueued to the RQ worker (queue=DESIGN_QUEUE)
# instead of running inline, so FastAPI stays responsive. Requires COPILOT_PERSIST=true
# (api + worker share job state via the DB). Compose sets this for the api.
# COPILOT_ASYNC_RUNS=true

# --- Live events (E2.4) ---
# When true, the api (chat) + worker (design run) publish structured events over Redis
# pub/sub and clients stream them via GET /jobs/{id}/events (SSE). Needs Redis. Compose
# sets this for the api + worker; leave unset for host tools/tests (no Redis needed).
# COPILOT_EVENTS=true

# --- Auth / multi-tenant (E2.5) ---
# When true, every /jobs route requires `Authorization: Bearer <key>` and is scoped to
# the key's tenant; Redis per-tenant rate limits apply. Needs COPILOT_PERSIST=true (the
# api_keys table lives in the DB). Compose sets this for the api; leave unset for host
# tools/tests (requests fall back to the dev tenant, no key needed).
# COPILOT_AUTH=true
# Dev bootstrap API key seeded on startup so local/demo use needs no signup.
COPILOT_DEV_API_KEY=dev-local-key
# Server-side secret mixed into the API-key hash (never store raw keys). Override this
# in production so a leaked DB cannot be used to forge keys.
COPILOT_API_KEY_PEPPER=copilot-dev-pepper

# --- Budgets (background guardrails; surfaced read-only in the workspace) ---
MAX_TOKENS_PER_SESSION=200000
MAX_DESIGN_ITERATIONS=12
RATE_LIMIT_PER_MINUTE=60

# --- React/Next UI (E3) ---
# Browser origins allowed to call the API (CORS). The web app runs on a different origin
# (default http://localhost:3000) than the API, so the browser needs this allow-list to
# send the Bearer key + read the SSE stream. Comma-separated; "*" allows any origin (dev
# convenience only — do not use "*" with real keys).
COPILOT_CORS_ORIGINS=http://localhost:3000
# The web service reads these (browser-visible). NEXT_PUBLIC_COPILOT_API_KEY defaults to
# COPILOT_DEV_API_KEY so the UI works out of the box; real per-user accounts come later.
# NEXT_PUBLIC_API_BASE=http://localhost:8000
