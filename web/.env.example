# Web (Next.js) — browser-visible config. Copy to .env.local for host `npm run dev`.
# In Docker Compose these are injected by the `web` service.

# Where the browser reaches the FastAPI backend (host-published port).
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Dev bootstrap API key (Authorization: Bearer). Matches COPILOT_DEV_API_KEY on the API.
# Real per-user accounts come later; this makes the UI work out of the box.
NEXT_PUBLIC_COPILOT_API_KEY=dev-local-key
